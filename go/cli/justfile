# List available commands.
default:
    @just --list

# Run the CLI. Example: just run version
run *args:
    go run ./cmd/me {{args}}

# Format Go sources.
fmt:
    go fmt ./...

# Run all tests.
test:
    go test ./...

# Run guarded live Hetzner Personal Server validation.
live-hetzner:
    ME_LIVE_HETZNER=1 go test ./internal/cli -run TestLivePersonalServerProvisioning -count=1 -timeout=30m -v

# Build the CLI binary at ./bin/me.
build:
    mkdir -p ./bin
    go build -o ./bin/me ./cmd/me

# Sync go.mod and go.sum with imports.
tidy:
    go mod tidy

# Build the CLI binary with release metadata. Example: just release 0.1.0
release version:
    mkdir -p ./bin
    go build -ldflags "-X main.version={{version}} -X main.commit=$(git rev-parse --short HEAD) -X main.date=$(date -u +%Y-%m-%dT%H:%M:%SZ)" -o ./bin/me ./cmd/me
